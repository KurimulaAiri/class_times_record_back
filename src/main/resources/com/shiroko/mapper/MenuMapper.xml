<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shiroko.mapper.MenuMapper">

    <resultMap id="BaseResultMap" type="com.shiroko.repository.entity.Menu">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="menuName" column="menu_name" jdbcType="VARCHAR"/>
            <result property="icon" column="icon" jdbcType="VARCHAR"/>
            <result property="iconType" column="icon_type" jdbcType="INTEGER"/>
            <result property="bgColor" column="bg_color" jdbcType="VARCHAR"/>
            <result property="path" column="path" jdbcType="VARCHAR"/>
            <result property="sortOrder" column="sort_order" jdbcType="INTEGER"/>
            <result property="isVisible" column="is_visible" jdbcType="TINYINT"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,menu_name,icon,
        icon_type,bg_color,path,
        sort_order,is_visible,create_time,
        update_time
    </sql>

    <select id="getMenuByRole" resultMap="BaseResultMap">
        SELECT
            m.id,
            m.menu_name,
            m.icon,
            m.icon_type,
            m.bg_color,
            m.path,
            m.sort_order,
            m.is_visible,
            m.create_time,
            m.update_time
        FROM menu m
        LEFT JOIN role_menu rm ON m.id = rm.menu_id
        WHERE rm.permission_id = #{queryMenuDTO.roleId}
    </select>
</mapper>
