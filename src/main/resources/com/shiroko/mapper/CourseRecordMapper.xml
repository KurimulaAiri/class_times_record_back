<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shiroko.mapper.CourseRecordMapper">

    <resultMap id="courseRecordResultMap" type="com.shiroko.repository.dto.courserecord.CourseRecordDTO">
        <id property="id" column="id"/>
        <result property="courseId" column="course_id"/>
        <result property="studentId" column="student_id"/>
        <result property="courseRestTime" column="course_rest_time"/>
        <result property="courseTotalTime" column="course_total_time"/>
        <result property="courseStatus" column="course_status"/>
        <result property="courseLastTime" column="course_last_time"/>
        <result property="expireTime" column="expire_time"/>
        <result property="isDelete" column="is_delete"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <association property="course" javaType="com.shiroko.repository.entity.Course">
            <id property="id" column="course_id"/>
            <result property="courseName" column="course_name"/>
            <result property="courseType" column="course_type"/>
            <result property="createTime" column="course_create_time"/>
        </association>
    </resultMap>

    <update id="updateRestTime">
        <!-- 1. 执行更新，同时利用 LAST_INSERT_ID() 记录下被更新行的 ID -->
        UPDATE course_record
        SET
        course_rest_time = course_rest_time - #{totalCount},
        course_last_time = NOW(),
        id = LAST_INSERT_ID(id)
        WHERE
        course_id = #{cr.courseId}
        AND student_id = #{cr.studentId}
        AND course_rest_time >= #{totalCount}

        <!-- 2. 更新完成后，将刚刚记录的 ID 提取出来赋给参数对象中的字段 -->
        <selectKey keyProperty="cr.id" resultType="long" order="AFTER">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </update>
    <select id="selectCourseCustomPage" resultType="com.shiroko.repository.vo.courserecord.CourseRecordVO">
        SELECT
        cr.*,
        s.student_name AS stuName
        FROM course_record cr
        LEFT JOIN student s ON cr.student_id = s.id
        <!-- 分享查询时，不关联权限记录 -->
        <if test="!dto.isShare">
            INNER JOIN permission_record pr ON cr.id = pr.course_record_id
        </if>

        <where>
            cr.is_delete = 0
            <if test="!dto.isShare">
                AND pr.user_id = #{dto.userId}
            </if>
            <if test="dto.id != null">
                AND cr.id = #{dto.id}
            </if>
            <if test="dto.courseStatus != null">
                AND cr.course_status = #{dto.courseStatus}
            </if>

            <!-- 简化后的搜索条件 -->
            <if test="dto.stuName != null or dto.courseName != null or dto.courseRemark != null">
                AND (
                <trim prefixOverrides="OR">
                    <if test="dto.stuName != null and dto.stuName != ''">
                        OR s.student_name LIKE CONCAT('%', #{dto.stuName}, '%')
                    </if>
                    <if test="dto.courseName != null and dto.courseName != ''">
                        OR cr.course_name LIKE CONCAT('%', #{dto.courseName}, '%')
                    </if>
                    <if test="dto.courseRemark != null and dto.courseRemark != ''">
                        OR cr.course_remark LIKE CONCAT('%', #{dto.courseRemark}, '%')
                    </if>
                </trim>
                )
            </if>
        </where>
        ORDER BY cr.update_time DESC, cr.id DESC
    </select>

    <select id="selectCourseRecords" resultMap="courseRecordResultMap">
        SELECT
        cr.*,
        c.id as course_id,
        c.course_name,
        c.course_type,
        c.create_time as course_create_time
        FROM
        course_record cr
        LEFT JOIN
        course c ON cr.course_id = c.id
        <where>
            <!-- 这里可以继续加你的条件，比如：-->
            <if test="dto.studentId != null">
                AND cr.student_id = #{dto.studentId}
            </if>
            AND cr.is_delete = 0
        </where>
    </select>

</mapper>
