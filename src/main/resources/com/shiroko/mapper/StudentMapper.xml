<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shiroko.mapper.StudentMapper">
    <select id="selectStudentByParentId" resultType="com.shiroko.repository.entity.Student">
        select s.*
        from parent_student ps
        left join student s on s.id = ps.student_id
        where ps.parent_id = #{dto.parentId}
    </select>
</mapper>
