<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shiroko.mapper.PermissionRecordMapper">

    <resultMap id="BaseResultMap" type="com.shiroko.repository.entity.PermissionRecord">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="courseRecordId" column="course_record_id" jdbcType="INTEGER"/>
            <result property="userId" column="user_id" jdbcType="INTEGER"/>
            <result property="permissionType" column="permission_type" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,course_record_id,user_id,permission_type
    </sql>

    <insert id="upsertPermission" parameterType="com.shiroko.repository.entity.PermissionRecord">
        INSERT INTO permission_record (user_id, course_record_id, permission_type)
        VALUES (#{userId}, #{courseRecordId}, #{permissionType})
        ON DUPLICATE KEY UPDATE permission_type = #{permissionType}
    </insert>

</mapper>
