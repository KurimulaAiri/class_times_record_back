<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="CONSOLE_LOG_PATTERN"
              value="%yellow(%d{yyyy-MM-dd HH:mm:ss.SSS}) | %highlight(%-5level) | %blue(%thread) | %cyan(%logger{50}) | %magenta(%msg) %n"/>

    <!-- 异步控制台输出：日志写入不阻塞业务线程，减少内存缓冲区 -->
    <appender name="ASYNC_STDOUT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="STDOUT" />
    </appender>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <!-- MyBatis Mapper 日志 -->
    <logger name="com.shiroko.repository.mapper" level="DEBUG" additivity="false">
        <appender-ref ref="ASYNC_STDOUT" />
    </logger>

    <!-- Spring MVC 相关日志降级 -->
    <logger name="org.springframework.web.servlet.DispatcherServlet" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_STDOUT" />
    </logger>
    <logger name="org.springframework.web.servlet.mvc.method.annotation" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_STDOUT" />
    </logger>

    <!-- 屏蔽 Sentinel 高频心跳INFO日志，只输出警告/错误 -->
    <logger name="com.alibaba.csp.sentinel.endpoint.SentinelHealthIndicator" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_STDOUT" />
    </logger>

    <!-- 如需关闭签名拦截器日志，取消下面注释即可 -->
    <!--
    <logger name="com.shiroko.interceptor.SignInterceptor" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_STDOUT" />
    </logger>
    -->

    <root level="INFO">
        <appender-ref ref="ASYNC_STDOUT" />
    </root>
</configuration>