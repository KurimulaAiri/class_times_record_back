pipeline {
    agent any

    environment {
        // ===================== 你的项目配置 =====================
        GIT_REPO_URL        = 'git@github.com:KurimulaAiri/class_times_record_back.git'
        GIT_BRANCH          = 'master'
        PROJECT_NAME        = 'class-times-record'
        APP_PORT            = 9999
        MAVEN_BUILD_CMD     = 'clean package -DskipTests'

        // 容器内挂载目录（你已经在编排里配置好，直接用）
        CONTAINER_DEPLOY_DIR = '/opt/deploy/class_times_record_back'

        // ===================== 宿主机 SSH 配置 =====================
        HOST_USER           = 'root'
        HOST_IP             = '172.21.0.1'   // Docker 容器访问宿主机 IP（正确）
        HOST_SSH_PORT       = 25184          // ✅ 你宿主机的 SSH 端口（关键修复）
        HOST_JAVA_CMD       = '/usr/bin/java'
        HOST_DEPLOY_DIR     = '/opt/java-deploy/class_times_record_back'
        HOST_PID_FILE       = "${HOST_DEPLOY_DIR}/${PROJECT_NAME}.pid"
    }

    tools {
        jdk 'Java17'
        maven '3.9.13'
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: 'MINUTES')
        // 构建前清空工作区（解决 Git 目录不为空）
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {
        // ===================== 1. 拉取代码（修复：先清空目录） =====================
        stage('拉取代码') {
            steps {
                echo '→ 清理工作区 + 拉取代码'
                sh 'rm -rf ./* .git* || true' // 强制清空，解决目录非空
                withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh-key', keyFileVariable: 'GIT_SSH_KEY_PATH')]) {
                    sh '''
                        export GIT_SSH_COMMAND="ssh -i ${GIT_SSH_KEY_PATH} -o StrictHostKeyChecking=no"
                        git clone -b ${GIT_BRANCH} ${GIT_REPO_URL} .
                    '''
                }
            }
        }

        // ===================== 2. 编译打包 =====================
        stage('编译打包') {
            steps {
                echo '→ 编译打包 SpringBoot'
                sh "mvn ${MAVEN_BUILD_CMD}"
            }
            post {
                failure { error '编译失败，终止部署' }
            }
        }

        // ===================== 3. 复制 jar 到共享目录（直接复制，已挂载） =====================
        stage('发布 jar 到宿主机') {
            steps {
                echo '→ 复制 jar 到共享目录'
                sh '''
                    JAR_FILE=$(ls target/*.jar | grep -v original | head -1)
                    cp -f $JAR_FILE ${CONTAINER_DEPLOY_DIR}/${PROJECT_NAME}.jar
                    echo "✅ jar 已同步到宿主机"
                '''
            }
        }

        // ===================== 4. 停止宿主机旧进程（SSH 端口 25184） =====================
        stage('停止旧进程') {
            steps {
                echo '→ 停止宿主机旧 Java 进程'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                            kill \$(cat ${HOST_PID_FILE}) 2>/dev/null || true
                            rm -f ${HOST_PID_FILE}
                        EOF
                    '''
                }
            }
        }

        // ===================== 5. 启动宿主机新进程（宿主机直接 nohup 运行） =====================
        stage('启动新进程') {
            steps {
                echo '→ 启动宿主机 SpringBoot 进程'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                            cd ${HOST_DEPLOY_DIR}
                            nohup ${HOST_JAVA_CMD} -jar ${PROJECT_NAME}.jar --server.port=${APP_PORT} > app.log 2>&1 &
                            echo \$! > ${HOST_PID_FILE}
                            sleep 2
                            echo "✅ 启动成功，端口：${APP_PORT}"
                        EOF
                    '''
                }
            }
        }
    }

    post {
        success {
            echo ''
            echo '=================================================='
            echo '                🎉 部署成功！'
            echo ' 项目：${PROJECT_NAME}'
            echo ' 端口：${APP_PORT}'
            echo ' 宿主机日志：${HOST_DEPLOY_DIR}/app.log'
            echo '=================================================='
        }
        failure {
            echo '❌ 部署失败，请检查日志'
        }
    }
}