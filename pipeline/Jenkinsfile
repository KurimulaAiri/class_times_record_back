pipeline {
    agent any

    environment {
        GIT_REPO_URL    = "git@github.com:KurimulaAiri/class_times_record_back.git"
        GIT_BRANCH      = "micro_service"
        MAVEN_BUILD_CMD = "clean package -Dmaven.test.skip=true"
        // 部署目标主机
        HOST_USER       = "root"
        HOST_IP         = "172.21.0.1"
        HOST_SSH_PORT   = "25184"
        // Gateway 直跑目录（非 Docker）
        HOST_GATEWAY_DIR  = "/opt/java-deploy/class_times_record_back/gateway"
        // Docker 微服务部署目录
        HOST_DOCKER_DIR   = "/opt/java-deploy/class_times_record_docker"
        // 基础设施
        DB_HOST         = "121.196.229.10"
        NACOS_ADDR      = "nacos.kurimula-airi.top"
        NACOS_NAMESPACE = "course-record"
        SENTINEL_ADDR   = "sentinel.kurimula-airi.top"
        COMPOSE_PROJECT = "class-times-record"
    }

    tools {
        jdk "Java"
        maven "3.9.13"
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: "MINUTES")
    }

    parameters {
        choice(name: 'DEPLOY_SCOPE', choices: ['all', 'gateway', 'auth-service', 'business-service', 'admin-service'], description: '部署范围')
        booleanParam(name: 'SKIP_BUILD', defaultValue: false, description: '跳过构建，直接部署')
        booleanParam(name: 'ROLLBACK', defaultValue: false, description: '回滚到上一版本')
    }

    stages {
        stage("Pull Code") {
            when { expression { params.ROLLBACK == false } }
            steps {
                echo "-> Pulling latest code from ${GIT_BRANCH}"
                withCredentials([sshUserPrivateKey(credentialsId: "github-ssh-key", keyFileVariable: "GIT_SSH_KEY_PATH")]) {
                    sh """
                        export GIT_SSH_COMMAND="ssh -i \${GIT_SSH_KEY_PATH} -o StrictHostKeyChecking=no"
                        git init || true
                        git remote add origin \${GIT_REPO_URL} || git remote set-url origin \${GIT_REPO_URL}
                        git fetch --all
                        git reset --hard origin/\${GIT_BRANCH}
                        git pull origin \${GIT_BRANCH} --force
                    """
                }
            }
        }

        stage("Build JARs") {
            when { expression { params.ROLLBACK == false && params.SKIP_BUILD == false } }
            steps {
                echo "-> Building all modules"
                sh "mvn \${MAVEN_BUILD_CMD}"
            }
            post {
                failure { error "Build failed" }
            }
        }

        stage("Deploy Gateway (JAR)") {
            when {
                expression { params.ROLLBACK == false }
                anyOf { expression { params.DEPLOY_SCOPE == 'all' }; expression { params.DEPLOY_SCOPE == 'gateway' } }
            }
            steps {
                echo "-> Deploying Gateway as standalone JAR"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        # 同步 JAR 到宿主机
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} "mkdir -p \${HOST_GATEWAY_DIR}"
                        # 排除 .original 薄包，只传输 fat JAR
                        scp -i \${HOST_SSH_KEY_PATH} -P \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \\
                            gateway/target/gateway-[0-9]*.jar \${HOST_USER}@\${HOST_IP}:\${HOST_GATEWAY_DIR}/gateway.jar

                        # 重启 Gateway
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} bash -s << 'GATEWAY_EOF'
GATEWAY_DIR="${HOST_GATEWAY_DIR}"
cd \$GATEWAY_DIR

# 查找并停止旧进程（匹配 gateway.jar）
OLD_PID=\$(pgrep -f gateway.jar || true)
if [ -n "\$OLD_PID" ]; then
    echo "Stopping old gateway (PID: \$OLD_PID)..."
    kill -15 \$OLD_PID 2>/dev/null || true
    sleep 3
    # 若未死则强制
    kill -9 \$OLD_PID 2>/dev/null || true
    sleep 1
fi

# 启动新 Gateway（BUILD_ID=dontKillMe 防止 Jenkins 误杀）
echo "Starting Gateway..."
export BUILD_ID=dontKillMe
# 查找可用的 Java：优先 JAVA_HOME，其次常见路径，最后 PATH
if [ -x "\$JAVA_HOME/bin/java" ]; then
    JAVA_CMD="\$JAVA_HOME/bin/java"
elif [ -x "/usr/local/jdk-21/bin/java" ]; then
    JAVA_CMD="/usr/local/jdk-21/bin/java"
elif [ -x "/usr/lib/jvm/java-21-openjdk/bin/java" ]; then
    JAVA_CMD="/usr/lib/jvm/java-21-openjdk/bin/java"
else
    JAVA_CMD="java"
fi
echo "Using Java: \$JAVA_CMD"
# JVM 内存优化参数（与 Dockerfile 保持一致）
nohup \$JAVA_CMD \\
  -Xms64m -Xmx128m \\
  -XX:+UseG1GC \\
  -XX:MaxGCPauseMillis=200 \\
  -Dspring.threads.virtual.enabled=true \\
  -Djava.security.egd=file:/dev/./urandom \\
  -XX:MaxMetaspaceSize=128m \\
  -XX:ReservedCodeCacheSize=64m \\
  -jar gateway.jar > gateway.log 2>&1 &
disown
sleep 2
# 验证进程存活
ps -ef | grep '[g]ateway.jar' | head -1
echo "Gateway deploy done"
GATEWAY_EOF
                    """
                }
            }
        }

        stage("Sync Docker Files") {
            when {
                expression { params.ROLLBACK == false }
                anyOf { expression { params.DEPLOY_SCOPE == 'all' }; expression { params.DEPLOY_SCOPE != 'gateway' } }
            }
            steps {
                echo "-> Syncing Dockerfiles and JARs for microservices"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} "mkdir -p \${HOST_DOCKER_DIR}"
                        # 同步 docker-compose.yml
                        scp -i \${HOST_SSH_KEY_PATH} -P \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \\
                            docker-compose.yml \${HOST_USER}@\${HOST_IP}:\${HOST_DOCKER_DIR}/
                        # 同步微服务 JAR + Dockerfile（不含 gateway）
                        for SVC in auth-service business-service admin-service; do
                            ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} "mkdir -p \${HOST_DOCKER_DIR}/\${SVC}/target"
                            scp -i \${HOST_SSH_KEY_PATH} -P \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \\
                                ./\${SVC}/target/\${SVC}-[0-9]*.jar \${HOST_USER}@\${HOST_IP}:\${HOST_DOCKER_DIR}/\${SVC}/target/
                            scp -i \${HOST_SSH_KEY_PATH} -P \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \\
                                ./\${SVC}/Dockerfile \${HOST_USER}@\${HOST_IP}:\${HOST_DOCKER_DIR}/\${SVC}/
                        done
                    """
                }
            }
        }

        stage("Build Docker & Deploy Microservices") {
            when {
                anyOf { expression { params.DEPLOY_SCOPE == 'all' }; expression { params.DEPLOY_SCOPE != 'gateway' } }
            }
            steps {
                echo "-> Building Docker images and deploying (scope: ${params.DEPLOY_SCOPE})"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} bash -s << 'DEPLOY_EOF'
cd "${HOST_DOCKER_DIR}"
export NACOS_ADDR="${NACOS_ADDR}"
export NACOS_NAMESPACE="${NACOS_NAMESPACE}"
export SENTINEL_ADDR="${SENTINEL_ADDR}"
export DB_ADDR="${DB_HOST}"
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT}"
DEPLOY_SCOPE="${params.DEPLOY_SCOPE}"
ROLLBACK="${params.ROLLBACK}"

# 确定要操作的微服务列表（排除 gateway，它直跑 JAR）
get_service_list() {
    if [ "\$DEPLOY_SCOPE" = "all" ]; then
        echo "auth-service business-service admin-service"
    elif [ "\$DEPLOY_SCOPE" != "gateway" ]; then
        echo "\$DEPLOY_SCOPE"
    else
        echo ""
    fi
}

# 回滚模式
if [ "\$ROLLBACK" = "true" ]; then
    echo "========== 回滚模式 =========="
    for SVC in \$(get_service_list); do
        BACKUP=\$(docker images -q cr-\${SVC}:backup 2>/dev/null)
        if [ -n "\$BACKUP" ]; then
            echo "-> 停止并删除容器 cr-\${SVC}..."
            docker compose stop \${SVC} 2>/dev/null || true
            docker compose rm -f \${SVC} 2>/dev/null || true
            echo "-> 恢复 \${SVC} 备份镜像..."
            docker tag cr-\${SVC}:backup cr-\${SVC}:latest
            echo "-> 启动 \${SVC}..."
            docker compose up -d \${SVC}
            echo "Restored \$SVC from backup"
        else
            echo "No backup found for \$SVC, skip"
        fi
    done
    echo "Rollback completed"
    exit 0
fi

# ========== 正常部署流程 ==========
SERVICES=\$(get_service_list)
echo "-> 本次部署范围: \${SERVICES}"

# 1) 备份现有镜像
echo "========== Step 1: 备份现有镜像 =========="
for SVC in \${SERVICES}; do
    EXISTING=\$(docker images -q cr-\${SVC}:latest 2>/dev/null)
    if [ -n "\$EXISTING" ]; then
        # 先删除旧的备份
        docker rmi cr-\${SVC}:backup 2>/dev/null || true
        docker tag cr-\${SVC}:latest cr-\${SVC}:backup
        echo "-> cr-\${SVC}:latest → cr-\${SVC}:backup"
    fi
done

# 2) 停止并删除旧容器
echo "========== Step 2: 停止并删除旧容器 =========="
for SVC in \${SERVICES}; do
    CONTAINER=\$(docker ps -a -q --filter "name=cr-\${SVC}" 2>/dev/null)
    if [ -n "\$CONTAINER" ]; then
        echo "-> 停止容器 cr-\${SVC}..."
        docker stop cr-\${SVC} 2>/dev/null || true
        echo "-> 删除容器 cr-\${SVC}..."
        docker rm cr-\${SVC} 2>/dev/null || true
    else
        echo "-> 容器 cr-\${SVC} 不存在，跳过"
    fi
done

# 3) 删除旧镜像（保留 backup 用于回滚）
echo "========== Step 3: 清理旧镜像 =========="
for SVC in \${SERVICES}; do
    OLD_IMAGE=\$(docker images -q cr-\${SVC}:latest 2>/dev/null)
    if [ -n "\$OLD_IMAGE" ]; then
        echo "-> 删除旧镜像 cr-\${SVC}:latest (ID: \$OLD_IMAGE)..."
        docker rmi cr-\${SVC}:latest 2>/dev/null || true
    else
        echo "-> 镜像 cr-\${SVC}:latest 不存在，跳过"
    fi
done

# 4) 构建新镜像
echo "========== Step 4: 构建新镜像 =========="
for SVC in \${SERVICES}; do
    echo "-> 构建 cr-\${SVC}:latest..."
    docker compose build \${SVC}
done

# 5) 启动新容器
echo "========== Step 5: 启动新容器 =========="
for SVC in \${SERVICES}; do
    echo "-> 启动 \${SVC}..."
    docker compose up -d \${SVC}
done

# 6) 清理悬空镜像（无标签的中间层镜像）
echo "========== Step 6: 清理悬空镜像 =========="
DANGLING_COUNT=\$(docker images -f "dangling=true" -q 2>/dev/null | wc -l)
if [ "\$DANGLING_COUNT" -gt 0 ]; then
    echo "-> 发现 \$DANGLING_COUNT 个悬空镜像，正在清理..."
    docker image prune -f
else
    echo "-> 无悬空镜像"
fi

# 清理停止的容器（安全兜底）
docker container prune -f 2>/dev/null || true

echo ""
echo "=========================================="
echo "       Docker Deploy Completed"
echo "=========================================="
for SVC in \${SERVICES}; do
    STATUS=\$(docker inspect -f '{{.State.Status}}' cr-\${SVC} 2>/dev/null || echo "unknown")
    echo "  \${SVC}: \${STATUS}"
done
echo "=========================================="
DEPLOY_EOF
                    """
                }
            }
        }

        stage("Verify") {
            steps {
                echo "-> Verifying all services"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} bash -s << 'VERIFY_EOF'
FAILED=0

verify_port() {
    local NAME=\$1
    local PORT=\$2
    for i in \$(seq 1 12); do
        if curl -sf "http://localhost:\$PORT/actuator/health" > /dev/null 2>&1; then
            echo "OK:   \$NAME (port \$PORT, health=UP)"
            return
        fi
        sleep 5
    done
    echo "WARN: \$NAME (port \$PORT, health check timeout)"
}

# Gateway（JAR 直跑）
echo "--- Gateway ---"
GW_PID=\$(ps aux | grep '[g]ateway.jar' | awk '{print \$2}')
if [ -n "\$GW_PID" ]; then
    verify_port "gateway" 9999
else
    echo "FAIL: gateway - process not found"
    FAILED=1
fi

# Docker 微服务
echo "--- Docker Microservices ---"
for SVC in auth-service business-service admin-service; do
    STATUS=\$(docker inspect -f '{{.State.Status}}' cr-\${SVC} 2>/dev/null)
    if [ "\$STATUS" = "running" ]; then
        case \$SVC in
            auth-service)     PORT=10002 ;;
            business-service) PORT=10001 ;;
            admin-service)    PORT=10003 ;;
        esac
        verify_port "\$SVC" \$PORT
    else
        echo "FAIL: \$SVC - container not running (status: \$STATUS)"
        docker compose -f ${HOST_DOCKER_DIR}/docker-compose.yml logs --tail=20 \$SVC 2>/dev/null
        FAILED=1
    fi
done

if [ \$FAILED -ne 0 ]; then
    echo ""
    echo "Some services failed verification!"
    exit 1
fi
VERIFY_EOF
                    """
                }
            }
        }
    }

    post {
        success {
            echo ""
            echo "=================================================="
            echo "              Deployment Success"
            echo "=================================================="
            echo " Gateway (JAR):    ${HOST_IP}:11011"
            echo " Auth (Docker):    ${HOST_IP}:10002"
            echo " Business (Docker):${HOST_IP}:10001"
            echo " Admin (Docker):   ${HOST_IP}:10003"
            echo "=================================================="
        }
        failure {
            echo ""
            echo "=================================================="
            echo "              Deployment Failed"
            echo " Gateway logs: tail -f ${HOST_GATEWAY_DIR}/gateway.log"
            echo " Docker logs:  docker compose logs <service>"
            echo " Rollback:     re-run with ROLLBACK=true"
            echo "=================================================="
        }
    }
}
