pipeline {
    agent any

    environment {
        // 代码仓库地址（SSH方式，需Jenkins配置Git私钥）
        GIT_REPO_URL = 'git@github.com:KurimulaAiri/class_times_record_back.git'
        GIT_BRANCH = 'master'
        // 项目名称
        PROJECT_NAME = 'class-times-record'
        // SpringBoot项目端口
        APP_PORT = 9999
        // Maven构建命令
        MAVEN_BUILD_CMD = 'clean package -DskipTests'
        // Jenkins容器内共享目录（已在容器编排中挂载，对应宿主机/opt/java-deploy/class_times_record_back）
        CONTAINER_DEPLOY_DIR = '/opt/deploy/class_times_record_back'
        // 宿主机SSH配置
        HOST_USER = 'root'  // 宿主机登录用户名（根据实际修改）
        HOST_IP = '192.168.1.100'  // 替换为宿主机真实内网IP
        // 宿主机PID文件路径（与共享目录对应）
        HOST_PID_FILE = "/opt/java-deploy/class_times_record_back/${PROJECT_NAME}.pid"
        // 宿主机Java命令路径
        HOST_JAVA_CMD = '/usr/bin/java'
    }

    tools {
        jdk 'Java17'    // Jenkins全局配置的JDK名称
        maven '3.9.13' // Jenkins全局配置的Maven名称
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        // 1. 拉取代码（移除目录创建阶段，直接拉取代码）
        stage('拉取代码') {
            steps {
                echo '拉取Git代码...'
                withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh-key', keyFileVariable: 'GIT_SSH_KEY')]) {
                    sh """
                        export GIT_SSH_COMMAND='ssh -i ${GIT_SSH_KEY} -o StrictHostKeyChecking=no'
                        git clone -b ${GIT_BRANCH} ${GIT_REPO_URL} .
                    """
                }
            }
        }

        // 2. 编译打包
        stage('编译打包') {
            steps {
                echo '编译打包SpringBoot项目...'
                sh "mvn ${MAVEN_BUILD_CMD}"
            }
            post {
                failure { echo '编译打包失败！'; error '终止构建' }
                success { echo '编译打包成功，生成jar包完成' }
            }
        }

        // 3. 同步jar包到共享目录（仅验证目录存在，不创建）
        stage('同步jar包到宿主机') {
            steps {
                echo '将jar包复制到共享目录（同步到宿主机）...'
                sh """
                    # 仅验证共享目录是否存在（容器编排已创建，无需重复mkdir）
                    if [ ! -d ${CONTAINER_DEPLOY_DIR} ]; then
                        echo '共享目录不存在！请检查容器编排挂载配置'
                        exit 1
                    fi
                    # 找到编译后的jar包（排除original-开头的原始包）
                    JAR_FILE=\$(ls target/*.jar | grep -v 'original-' | head -1)
                    if [ -z "\$JAR_FILE" ]; then
                        echo '未找到编译后的jar包！'
                        exit 1
                    fi
                    # 直接复制到已挂载的共享目录（自动同步到宿主机）
                    cp \$JAR_FILE ${CONTAINER_DEPLOY_DIR}/${PROJECT_NAME}.jar
                    # 验证jar包同步结果
                    if [ -f ${CONTAINER_DEPLOY_DIR}/${PROJECT_NAME}.jar ]; then
                        echo 'jar包同步到宿主机成功'
                    else
                        echo 'jar包同步失败'
                        exit 1
                    fi
                """
            }
        }

        // 4. 停止宿主机旧Java进程（SSH直接执行）
        stage('停止旧Java进程') {
            steps {
                echo '停止宿主机上的旧Java进程...'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'SSH_KEY')]) {
                    sh """
                        ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                            # 通过PID文件停止进程
                            if [ -f ${HOST_PID_FILE} ]; then
                                PID=\$(cat ${HOST_PID_FILE})
                                kill -9 \$PID 2>/dev/null || echo '旧进程已停止或不存在'
                                rm -f ${HOST_PID_FILE}
                            fi
                            # 通过端口兜底停止
                            PORT_PID=\$(netstat -tlnp | grep :${APP_PORT} | awk '{print \$7}' | cut -d/ -f1)
                            if [ -n "\$PORT_PID" ]; then
                                kill -9 \$PORT_PID && echo '通过端口停止旧进程成功'
                            fi
                        EOF
                    """
                }
            }
        }

        // 5. 启动宿主机新Java进程（SSH直接执行）
        stage('启动新Java进程') {
            steps {
                echo '在宿主机启动SpringBoot进程...'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'SSH_KEY')]) {
                    sh """
                        ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                            # 后台启动SpringBoot进程，输出日志到共享目录
                            nohup ${HOST_JAVA_CMD} -jar /opt/java-deploy/class_times_record_back/${PROJECT_NAME}.jar \
                            --server.port=${APP_PORT} > /opt/java-deploy/class_times_record_back/app.log 2>&1 &
                            # 记录进程PID到共享目录
                            echo \$! > ${HOST_PID_FILE}
                            # 验证进程启动
                            sleep 3
                            if netstat -tlnp | grep :${APP_PORT}; then
                                echo 'SpringBoot进程启动成功'
                            else
                                echo '进程启动失败！日志路径：/opt/java-deploy/class_times_record_back/app.log'
                                exit 1
                            fi
                        EOF
                    """
                }
            }
        }
    }

    post {
        always {
            echo 'CI/CD流程结束'
            // 验证宿主机进程状态
            withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'SSH_KEY')]) {
                sh """
                    echo '宿主机${APP_PORT}端口进程状态：'
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                        netstat -tlnp | grep ${APP_PORT} || echo '无进程占用${APP_PORT}端口'
                    EOF
                """
            }
        }
        success {
            echo "===== 部署完成！====="
            echo "宿主机部署目录：/opt/java-deploy/class_times_record_back"
            echo "访问地址：http://${HOST_IP}:${APP_PORT}"
            echo "日志文件：/opt/java-deploy/class_times_record_back/app.log"
        }
        failure {
            echo "===== 部署失败！请检查Jenkins控制台日志 ====="
        }
    }
}