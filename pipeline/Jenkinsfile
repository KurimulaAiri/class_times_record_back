pipeline {
    agent any

    environment {
        // 项目基础配置
        GIT_REPO_URL        = 'git@github.com:KurimulaAiri/class_times_record_back.git'
        GIT_BRANCH          = 'master'
        PROJECT_NAME        = 'class-times-record'
        APP_PORT            = 9999
        MAVEN_BUILD_CMD     = 'clean package -DskipTests'

        // 容器内共享目录（已挂载）
        CONTAINER_DEPLOY_DIR = '/opt/deploy/class_times_record_back'

        // 宿主机配置（核心：修复 Java 路径）
        HOST_USER           = 'root'
        HOST_IP             = '172.21.0.1'
        HOST_SSH_PORT       = 25184
        HOST_JAVA_CMD       = '/www/server/java/jdk-17.0.8/bin/java'  // 你的 Java 实际路径
        HOST_DEPLOY_DIR     = '/opt/java-deploy/class_times_record_back'
        HOST_PID_FILE       = "${HOST_DEPLOY_DIR}/${PROJECT_NAME}.pid"
    }

    tools {
        jdk 'Java17'
        maven '3.9.13'
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        // 1. 拉取代码
        stage('拉取代码') {
            steps {
                echo '→ 拉取最新代码'
                withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh-key', keyFileVariable: 'GIT_SSH_KEY_PATH')]) {
                    sh '''
                        export GIT_SSH_COMMAND="ssh -i ${GIT_SSH_KEY_PATH} -o StrictHostKeyChecking=no"
                        git init || true
                        git remote add origin ${GIT_REPO_URL} || git remote set-url origin ${GIT_REPO_URL}
                        git fetch --all
                        git reset --hard origin/${GIT_BRANCH}
                        git pull origin ${GIT_BRANCH} --force
                    '''
                }
            }
        }

        // 2. 编译打包
        stage('编译打包') {
            steps {
                echo '→ 编译打包 SpringBoot 项目'
                sh "mvn ${MAVEN_BUILD_CMD}"
            }
            post {
                failure { error '编译打包失败，终止部署' }
                success { echo '✅ 编译打包成功' }
            }
        }

        // 3. 发布 jar 到宿主机
        stage('发布 jar 到宿主机') {
            steps {
                echo '→ 同步 jar 包到宿主机共享目录'
                sh '''
                    if [ ! -w ${CONTAINER_DEPLOY_DIR} ]; then
                        chmod 777 ${CONTAINER_DEPLOY_DIR} || true
                    fi
                    JAR_FILE=$(ls target/*.jar | grep -v 'original-' | head -1)
                    cp -f $JAR_FILE ${CONTAINER_DEPLOY_DIR}/${PROJECT_NAME}.jar
                    echo '✅ jar 包已同步到宿主机'
                '''
            }
        }

        // 4. 停止旧进程
        stage('停止旧进程') {
            steps {
                echo "→ 正在安全停止宿主机端口为 ${APP_PORT} 的 Java 进程"
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                        # --- 远程执行开始 ---

                        # 1. 优先通过 PID 文件停止
                        if [ -f "${HOST_PID_FILE}" ]; then
                            OLD_PID=$(cat "${HOST_PID_FILE}")
                            echo "找到 PID 文件，尝试停止进程: $OLD_PID"
                            if ps -p $OLD_PID > /dev/null; then
                                kill $OLD_PID || kill -9 $OLD_PID
                                echo "✅ 已通过 PID 文件停止进程"
                            fi
                            rm -f "${HOST_PID_FILE}"
                        fi

                        # 2. 强制通过端口检查（防止 PID 文件失效后的残留进程）
                        # 尝试多种方式获取 PID：lsof (最准) 或 netstat
                        PORT_PID=$(lsof -t -i:${APP_PORT} 2>/dev/null || netstat -lnpt 2>/dev/null | grep ":${APP_PORT} " | awk '{print $7}' | cut -d'/' -f1 | grep -o '[0-9]\\+')

                        if [ -n "$PORT_PID" ]; then
                            echo "警告：端口 ${APP_PORT} 仍被进程 $PORT_PID 占用，执行强制杀除"
                            for pid in $PORT_PID; do
                                kill -9 $pid 2>/dev/null && echo "✅ 已杀除残留进程: $pid"
                            done
                        else
                            echo "✅ 端口 ${APP_PORT} 目前干净，可以启动"
                        fi

                        # --- 远程执行结束 ---
EOF
                    '''
                }
            }
        }

        // 5. 启动新进程
        stage('启动新进程') {
            steps {
                echo '→ 启动宿主机 SpringBoot 进程（prod 环境）'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                        # --- 远程执行开始 ---

                        LOG_FILE="${HOST_DEPLOY_DIR}/${PROJECT_NAME}.log"

                        # 1. 异步启动项目
                        echo "开始启动项目并记录日志到: ${LOG_FILE}"
                        nohup ${HOST_JAVA_CMD} -jar ${HOST_DEPLOY_DIR}/${PROJECT_NAME}.jar \
                            --server.port=${APP_PORT} \
                            --spring.profiles.active=prod > "${LOG_FILE}" 2>&1 &

                        NEW_PID=$!
                        echo $NEW_PID > "${HOST_PID_FILE}"


                        # 2. 动态监测日志（最多等待 60 秒）
                        echo "正在等待 Spring Boot 完成初始化..."
                        MAX_WAIT=60
                        CUR=0

                        SUCCESS=false

                        while [ $CUR -lt $MAX_WAIT ]; do
                            # 检查日志是否出现成功标识
                            if grep -q "Started .* in .* seconds" "${LOG_FILE}"; then
                                SUCCESS=true
                                break
                            fi

                            # 检查进程是否意外挂掉（例如数据库连不上）
                            if ! ps -p $NEW_PID > /dev/null; then
                                echo "❌ 进程启动后异常退出！最后 50 行日志："
                                tail -n 50 "${LOG_FILE}"
                                exit 1
                            fi

                            sleep 1
                            CUR=$((CUR + 1))

                            [ $((CUR % 10)) -eq 0 ] && echo "已等待 ${CUR}s..."
                        done

                        if [ "$SUCCESS" = true ]; then
                            echo "🎉 项目启动成功！PID: $NEW_PID"
                            echo "访问地址：http://${HOST_IP}:${APP_PORT}"
                        else
                            echo "❌ 启动超时，请检查完整日志：${LOG_FILE}"
                            exit 1
                        fi

                        # --- 远程执行结束 ---
EOF
                    '''
                }
            }
        }
    }

    post {
        success {
            echo ''
            echo '=================================================='
            echo '                🎉 部署全流程成功！'
            echo " 项目名称：${PROJECT_NAME}"
            echo " 运行环境：prod（生产环境）"
            echo " 访问地址：http://${HOST_IP}:${APP_PORT}"
            echo " 日志路径：${HOST_DEPLOY_DIR}/app.log"
            echo '=================================================='
        }
        failure {
            echo ''
            echo '=================================================='
            echo '                ❌ 部署失败！'
            echo ' 核心原因：Java 路径错误 / 应用启动失败'
            echo ' 请检查：1. 宿主机 Java 路径  2. 应用日志'
            echo '=================================================='
        }
    }
}