pipeline {
    agent any

    environment {
        // 项目基础配置
        GIT_REPO_URL        = 'git@github.com:KurimulaAiri/class_times_record_back.git'
        GIT_BRANCH          = 'master'
        PROJECT_NAME        = 'class-times-record'
        APP_PORT            = 9999
        MAVEN_BUILD_CMD     = 'clean package -DskipTests'

        // 容器内共享目录（已挂载到宿主机 /opt/java-deploy/...）
        CONTAINER_DEPLOY_DIR = '/opt/deploy/class_times_record_back'

        // 宿主机配置
        HOST_USER           = 'root'
        HOST_IP             = '172.21.0.1'
        HOST_SSH_PORT       = 25184
        HOST_JAVA_CMD       = '/www/server/java/jdk-17.0.8/bin/java'
        HOST_DEPLOY_DIR     = '/opt/java-deploy/class_times_record_back'
        HOST_PID_FILE       = "${HOST_DEPLOY_DIR}/${PROJECT_NAME}.pid"
    }

    tools {
        jdk 'Java17'
        maven '3.9.13'
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        // 1. 拉取代码
        stage('拉取代码') {
            steps {
                echo '→ 拉取最新代码'
                withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh-key', keyFileVariable: 'GIT_SSH_KEY_PATH')]) {
                    sh '''
                        export GIT_SSH_COMMAND="ssh -i ${GIT_SSH_KEY_PATH} -o StrictHostKeyChecking=no"
                        git init || true
                        git remote add origin ${GIT_REPO_URL} || git remote set-url origin ${GIT_REPO_URL}
                        git fetch --all
                        git reset --hard origin/${GIT_BRANCH}
                        git pull origin ${GIT_BRANCH} --force
                    '''
                }
            }
        }

        // 2. 编译打包
        stage('编译打包') {
            steps {
                echo '→ 编译打包 SpringBoot 项目'
                sh "mvn ${MAVEN_BUILD_CMD}"
            }
            post {
                failure { error '编译打包失败，终止部署' }
                success { echo '✅ 编译打包成功' }
            }
        }

        // 3. 发布 jar 到宿主机
        stage('发布 jar 到宿主机') {
            steps {
                echo '→ 同步 jar 包到宿主机共享目录'
                sh '''
                    if [ ! -w ${CONTAINER_DEPLOY_DIR} ]; then
                        chmod 777 ${CONTAINER_DEPLOY_DIR} || true
                    fi
                    JAR_FILE=$(ls target/*.jar | grep -v 'original-' | head -1)
                    cp -f $JAR_FILE ${CONTAINER_DEPLOY_DIR}/${PROJECT_NAME}.jar
                    echo '✅ jar 包已同步到宿主机'
                '''
            }
        }

        // 4. 停止旧进程 (修复重点：防止变量在容器内解析)
        stage('停止旧进程') {
            steps {
                echo "→ 停止宿主机端口为 ${APP_PORT} 的进程"
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << 'EOF'
                        # 注入变量（因为使用了 'EOF'，需要重新手动指定这些来自 Jenkins 的变量）
                        PORT=''' + APP_PORT + '''
                        PID_FILE=''' + HOST_PID_FILE + '''

                        # 1. 尝试通过 PID 文件停止
                        if [ -f "$PID_FILE" ]; then
                            OLD_PID=$(cat "$PID_FILE")
                            kill -9 $OLD_PID 2>/dev/null || true
                            rm -f "$PID_FILE"
                        fi

                        # 2. 检查端口占用（解决 grep 转义报错，改用 tr 过滤）
                        PORT_PID=$(netstat -tlnp 2>/dev/null | grep ":$PORT " | awk '{print $7}' | cut -d/ -f1 | tr -cd '0-9\\n')
                        if [ -n "$PORT_PID" ]; then
                            echo "杀除端口 $PORT 残留进程: $PORT_PID"
                            kill -9 $PORT_PID 2>/dev/null || true
                        fi
                        echo "✅ 旧进程清理完成"
EOF
                    '''
                }
            }
        }

        // 5. 启动新进程 (修复重点：路径一致性 + 动态监测)
        stage('启动新进程') {
            steps {
                echo "→ 启动宿主机进程（端口: ${APP_PORT}）"
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << 'EOF'
                        # 注入变量
                        JAVA_CMD=''' + HOST_JAVA_CMD + '''
                        DEPLOY_DIR=''' + HOST_DEPLOY_DIR + '''
                        PROJ_NAME=''' + PROJECT_NAME + '''
                        PORT=''' + APP_PORT + '''
                        PID_FILE=''' + HOST_PID_FILE + '''
                        LOG_FILE="$DEPLOY_DIR/$PROJ_NAME.log"

                        # 执行启动
                        nohup $JAVA_CMD -jar $DEPLOY_DIR/$PROJ_NAME.jar \
                            --server.port=$PORT \
                            --spring.profiles.active=prod > "$LOG_FILE" 2>&1 &

                        echo $! > "$PID_FILE"

                        # 动态监测日志，看到 Started 标识才认为成功
                        echo "等待启动中，查看日志: $LOG_FILE"
                        for i in {1..60}; do
                            if grep -q "Started .* in .* seconds" "$LOG_FILE" 2>/dev/null; then
                                echo "🎉 启动成功！"
                                exit 0
                            fi
                            # 进程是否还在运行
                            if ! ps -p $(cat $PID_FILE) > /dev/null; then
                                echo "❌ 启动失败，查看日志末尾："
                                tail -n 20 "$LOG_FILE"
                                exit 1
                            fi
                            sleep 1
                        done
                        echo "❌ 启动超时"
                        exit 1
EOF
                    '''
                }
            }
        }
    }

    post {
        success {
            echo ''
            echo '=================================================='
            echo '                🎉 部署全流程成功！'
            echo " 项目名称：${PROJECT_NAME}"
            echo " 运行环境：prod（生产环境）"
            echo " 访问地址：http://${HOST_IP}:${APP_PORT}"
            echo " 日志路径：${HOST_DEPLOY_DIR}/app.log"
            echo '=================================================='
        }
        failure {
            echo ''
            echo '=================================================='
            echo '                ❌ 部署失败！'
            echo ' 核心原因：Java 路径错误 / 应用启动失败'
            echo ' 请检查：1. 宿主机 Java 路径  2. 应用日志'
            echo '=================================================='
        }
    }
}