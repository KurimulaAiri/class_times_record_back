pipeline {
    agent any

    environment {
        GIT_REPO_URL    = "git@github.com:KurimulaAiri/class_times_record_back.git"
        GIT_BRANCH      = "master"
        PROJECT_NAME    = "class-times-record"
        MAVEN_BUILD_CMD = "clean package -Dmaven.test.skip=true"
        // 部署目标主机（Jenkins 容器通过 SSH 连接宿主机执行 docker compose）
        HOST_USER       = "root"
        HOST_IP         = "172.21.0.1"
        HOST_SSH_PORT   = 25184
        HOST_DEPLOY_DIR = "/opt/java-deploy/class_times_record_back"
        DB_HOST         = "172.17.0.1"
        COMPOSE_PROJECT = "class-times-record"
    }

    tools {
        jdk "Java"
        maven "3.9.13"
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: "MINUTES")
    }

    parameters {
        choice(name: 'DEPLOY_SCOPE', choices: ['all', 'gateway', 'auth-service', 'business-service'], description: '部署范围：all=全部，或指定单个服务')
        booleanParam(name: 'SKIP_BUILD', defaultValue: false, description: '跳过构建，直接部署')
        booleanParam(name: 'ROLLBACK', defaultValue: false, description: '回滚到上一版本镜像')
    }

    stages {
        stage("Pull Code") {
            when { expression { params.ROLLBACK == false } }
            steps {
                echo "-> Pulling latest code from ${GIT_BRANCH}"
                withCredentials([sshUserPrivateKey(credentialsId: "github-ssh-key", keyFileVariable: "GIT_SSH_KEY_PATH")]) {
                    sh """
                        export GIT_SSH_COMMAND="ssh -i \${GIT_SSH_KEY_PATH} -o StrictHostKeyChecking=no"
                        git init || true
                        git remote add origin \${GIT_REPO_URL} || git remote set-url origin \${GIT_REPO_URL}
                        git fetch --all
                        git reset --hard origin/\${GIT_BRANCH}
                        git pull origin \${GIT_BRANCH} --force
                    """
                }
            }
        }

        stage("Build JARs") {
            when { expression { params.ROLLBACK == false && params.SKIP_BUILD == false } }
            steps {
                echo "-> Building all modules"
                sh "mvn \${MAVEN_BUILD_CMD}"
            }
            post {
                failure { error "Build failed" }
                success { echo "Build success" }
            }
        }

        stage("Sync to Host") {
            when { expression { params.ROLLBACK == false } }
            steps {
                echo "-> Syncing project to host deploy dir"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} "mkdir -p \${HOST_DEPLOY_DIR}"
                        # Sync only needed files (JARs, Dockerfiles, docker-compose.yml)
                        rsync -azP -e "ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no" \\
                            pom.xml docker-compose.yml \${HOST_USER}@\${HOST_IP}:\${HOST_DEPLOY_DIR}/
                        for SVC in gateway auth-service business-service; do
                            rsync -azP --include='target/*.jar' --include='Dockerfile' --include='*/' --exclude='*' \\
                                -e "ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no" \\
                                ./\${SVC}/ \${HOST_USER}@\${HOST_IP}:\${HOST_DEPLOY_DIR}/\${SVC}/
                        done
                    """
                }
            }
        }

        stage("Build Docker Images & Deploy") {
            steps {
                echo "-> Building images and deploying (scope: ${params.DEPLOY_SCOPE})"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} bash -s << 'DEPLOY_EOF'
cd "${HOST_DEPLOY_DIR}"
export DB_HOST="${DB_HOST}"
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT}"
DEPLOY_SCOPE="${params.DEPLOY_SCOPE}"
ROLLBACK="${params.ROLLBACK}"

# Tag current images as backup before deploying
if [ "\$ROLLBACK" = "false" ]; then
    for SVC in gateway auth-service business-service; do
        EXISTING=\$(docker images -q \${COMPOSE_PROJECT_NAME}_\${SVC}:latest 2>/dev/null)
        if [ -n "\$EXISTING" ]; then
            docker tag \${COMPOSE_PROJECT_NAME}_\${SVC}:latest \${COMPOSE_PROJECT_NAME}_\${SVC}:backup 2>/dev/null || true
        fi
    done
fi

# Rollback: retag backup images
if [ "\$ROLLBACK" = "true" ]; then
    echo "-> Rolling back to previous images"
    for SVC in gateway auth-service business-service; do
        BACKUP=\$(docker images -q \${COMPOSE_PROJECT_NAME}_\${SVC}:backup 2>/dev/null)
        if [ -n "\$BACKUP" ]; then
            docker tag \${COMPOSE_PROJECT_NAME}_\${SVC}:backup \${COMPOSE_PROJECT_NAME}_\${SVC}:latest
            echo "Restored \$SVC from backup"
        else
            echo "No backup found for \$SVC"
        fi
    done
fi

# Build and deploy based on scope
BUILD_ARGS=""
if [ "\$DEPLOY_SCOPE" != "all" ]; then
    BUILD_ARGS="--no-deps build \$DEPLOY_SCOPE && docker compose up -d \$DEPLOY_SCOPE"
else
    BUILD_ARGS="build && docker compose up -d"
fi

if [ "\$ROLLBACK" = "false" ]; then
    docker compose build \$([ "\$DEPLOY_SCOPE" = "all" ] && echo "" || echo "\$DEPLOY_SCOPE")
fi

# Start Nacos first if not running
if ! docker compose ps nacos | grep -q "running"; then
    echo "-> Starting Nacos..."
    docker compose up -d nacos
    echo "-> Waiting for Nacos to be healthy..."
    for i in \$(seq 1 60); do
        if docker compose exec nacos curl -sf http://localhost:8848/nacos/ > /dev/null 2>&1; then
            echo "Nacos is healthy"
            break
        fi
        if [ \$i -eq 60 ]; then
            echo "Nacos health check timeout"
            exit 1
        fi
        sleep 2
    done
fi

# Start services (downstream first, gateway last)
if [ "\$DEPLOY_SCOPE" = "all" ]; then
    docker compose up -d auth-service business-service
    sleep 10
    docker compose up -d gateway
else
    docker compose up -d \$DEPLOY_SCOPE
fi

echo "Deploy completed"
DEPLOY_EOF
                    """
                }
            }
        }

        stage("Verify") {
            steps {
                echo "-> Verifying services"
                withCredentials([sshUserPrivateKey(credentialsId: "host-ssh-key", keyFileVariable: "HOST_SSH_KEY_PATH")]) {
                    sh """
                        ssh -i \${HOST_SSH_KEY_PATH} -p \${HOST_SSH_PORT} -o StrictHostKeyChecking=no \${HOST_USER}@\${HOST_IP} bash -s << 'VERIFY_EOF'
cd "${HOST_DEPLOY_DIR}"
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT}"
FAILED=0

verify_service() {
    local NAME=\$1
    local PORT=\$2
    local CONTAINER="\${COMPOSE_PROJECT_NAME}-\${NAME}-1"

    # Check container is running
    STATUS=\$(docker inspect -f '{{.State.Status}}' \$CONTAINER 2>/dev/null)
    if [ "\$STATUS" != "running" ]; then
        echo "FAIL: \$NAME - container not running (status: \$STATUS)"
        docker compose logs --tail=20 \$NAME 2>/dev/null
        FAILED=1
        return
    fi

    # Health check via HTTP
    sleep 3
    if curl -sf "http://localhost:\$PORT/actuator/health" > /dev/null 2>&1; then
        echo "OK:   \$NAME (port \$PORT, health=UP)"
    elif curl -sf "http://localhost:\$PORT/" > /dev/null 2>&1; then
        echo "OK:   \$NAME (port \$PORT, responding)"
    else
        echo "WARN: \$NAME (port \$PORT, container running but not responding yet)"
    fi
}

verify_service "auth-service" 8081
verify_service "business-service" 8082
verify_service "gateway" 8080

# Check Nacos registration
echo ""
echo "--- Nacos Service Registry ---"
docker compose exec nacos curl -sf "http://localhost:8848/nacos/v1/ns/service/list?pageNo=1&pageSize=10" 2>/dev/null || echo "Cannot query Nacos"

if [ \$FAILED -ne 0 ]; then
    echo ""
    echo "Some services failed verification!"
    exit 1
fi
VERIFY_EOF
                    """
                }
            }
        }
    }

    post {
        success {
            echo ""
            echo "=================================================="
            echo "       Deployment Success (Docker Microservices)"
            echo " Scope:         ${params.DEPLOY_SCOPE}"
            echo " Gateway:       http://${HOST_IP}:8080"
            echo " Auth Service:  http://${HOST_IP}:8081"
            echo " Business Svc:  http://${HOST_IP}:8082"
            echo " Nacos:         http://${HOST_IP}:8848/nacos"
            echo "=================================================="
        }
        failure {
            echo ""
            echo "=================================================="
            echo "            Deployment Failed"
            echo " Check: docker compose logs <service>"
            echo " Rollback: re-run pipeline with ROLLBACK=true"
            echo "=================================================="
        }
    }
}
