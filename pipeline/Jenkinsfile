pipeline {
    agent any

    environment {
        // 项目基础配置
        GIT_REPO_URL        = 'git@github.com:KurimulaAiri/class_times_record_back.git'
        GIT_BRANCH          = 'master'
        PROJECT_NAME        = 'class-times-record'
        APP_PORT            = 9999
        MAVEN_BUILD_CMD     = 'clean package -DskipTests'

        // 容器内共享目录（已挂载）
        CONTAINER_DEPLOY_DIR = '/opt/deploy/class_times_record_back'

        // 宿主机配置（核心：修复 Java 路径）
        HOST_USER           = 'root'
        HOST_IP             = '172.21.0.1'
        HOST_SSH_PORT       = 25184
        HOST_JAVA_CMD       = '/www/server/java/jdk-17.0.8/bin/java'  // 你的 Java 实际路径
        HOST_DEPLOY_DIR     = '/opt/java-deploy/class_times_record_back'
        HOST_PID_FILE       = "${HOST_DEPLOY_DIR}/${PROJECT_NAME}.pid"
    }

    tools {
        jdk 'Java17'
        maven '3.9.13'
    }

    options {
        skipDefaultCheckout true
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        // 1. 拉取代码
        stage('拉取代码') {
            steps {
                echo '→ 拉取最新代码'
                withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh-key', keyFileVariable: 'GIT_SSH_KEY_PATH')]) {
                    sh '''
                        export GIT_SSH_COMMAND="ssh -i ${GIT_SSH_KEY_PATH} -o StrictHostKeyChecking=no"
                        git init || true
                        git remote add origin ${GIT_REPO_URL} || git remote set-url origin ${GIT_REPO_URL}
                        git fetch --all
                        git reset --hard origin/${GIT_BRANCH}
                        git pull origin ${GIT_BRANCH} --force
                    '''
                }
            }
        }

        // 2. 编译打包
        stage('编译打包') {
            steps {
                echo '→ 编译打包 SpringBoot 项目'
                sh "mvn ${MAVEN_BUILD_CMD}"
            }
            post {
                failure { error '编译打包失败，终止部署' }
                success { echo '✅ 编译打包成功' }
            }
        }

        // 3. 发布 jar 到宿主机
        stage('发布 jar 到宿主机') {
            steps {
                echo '→ 同步 jar 包到宿主机共享目录'
                sh '''
                    if [ ! -w ${CONTAINER_DEPLOY_DIR} ]; then
                        chmod 777 ${CONTAINER_DEPLOY_DIR} || true
                    fi
                    JAR_FILE=$(ls target/*.jar | grep -v 'original-' | head -1)
                    cp -f $JAR_FILE ${CONTAINER_DEPLOY_DIR}/${PROJECT_NAME}.jar
                    echo '✅ jar 包已同步到宿主机'
                '''
            }
        }

        // 4. 停止旧进程
        stage('停止旧进程') {
            steps {
                echo '→ 停止宿主机旧 Java 进程'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                        rm -f /var/run/yum.pid 2>/dev/null
                        yum -y install net-tools --skip-broken --nogpgcheck
                        if [ -f ${HOST_PID_FILE} ]; then
                            kill -9 \$(cat ${HOST_PID_FILE}) 2>/dev/null || true
                            rm -f ${HOST_PID_FILE}
                        fi
                        PORT_PID=\$(netstat -tlnp 2>/dev/null | grep :${APP_PORT} | awk '{print \$7}' | cut -d/ -f1)
                        if [ -n "\$PORT_PID" ]; then
                            kill -9 \$PORT_PID 2>/dev/null || true
                        fi
                        echo "✅ 旧进程清理完成"
EOF
                    '''
                }
            }
        }

        // 5. 启动新进程（核心修改：激活 prod 环境 + 打印全部日志）
        stage('启动新进程') {
            steps {
                echo '→ 启动宿主机 SpringBoot 进程（prod 环境）'
                withCredentials([sshUserPrivateKey(credentialsId: 'host-ssh-key', keyFileVariable: 'HOST_SSH_KEY_PATH')]) {
                    sh '''
                        ssh -i ${HOST_SSH_KEY_PATH} -p ${HOST_SSH_PORT} -o StrictHostKeyChecking=no ${HOST_USER}@${HOST_IP} << EOF
                        # 验证 Java 路径是否存在
                        if [ ! -f ${HOST_JAVA_CMD} ]; then
                            echo "❌ Java 路径错误：${HOST_JAVA_CMD} 不存在"
                            echo "✅ 可用的 Java 路径："
                            find / -name java -type f -executable 2>/dev/null | head -5
                            exit 1
                        fi

                        # 启动进程（核心修改：添加 --spring.profiles.active=prod 激活生产环境）
                        nohup ${HOST_JAVA_CMD} -jar ${HOST_DEPLOY_DIR}/${PROJECT_NAME}.jar \
                        --server.port=${APP_PORT} \
                        --spring.profiles.active=prod > ${HOST_DEPLOY_DIR}/app.log 2>&1 &

                        echo \$! > ${HOST_PID_FILE} 2>/dev/null || true

                        # 验证启动结果（核心修改：打印全部日志）
                        sleep 5
                        if netstat -tlnp 2>/dev/null | grep :${APP_PORT}; then
                            echo "🎉 项目启动成功！（prod 环境）访问地址：http://${HOST_IP}:${APP_PORT}"
                        else
                            echo "❌ 项目启动失败，完整日志："
                            cat ${HOST_DEPLOY_DIR}/app.log  # 替换 tail -20 为 cat，打印全部日志
                            exit 1
                        fi
EOF
                    '''
                }
            }
        }
    }

    post {
        success {
            echo ''
            echo '=================================================='
            echo '                🎉 部署全流程成功！'
            echo " 项目名称：${PROJECT_NAME}"
            echo " 运行环境：prod（生产环境）"
            echo " 访问地址：http://${HOST_IP}:${APP_PORT}"
            echo " 日志路径：${HOST_DEPLOY_DIR}/app.log"
            echo '=================================================='
        }
        failure {
            echo ''
            echo '=================================================='
            echo '                ❌ 部署失败！'
            echo ' 核心原因：Java 路径错误 / 应用启动失败'
            echo ' 请检查：1. 宿主机 Java 路径  2. 应用日志'
            echo '=================================================='
        }
    }
}